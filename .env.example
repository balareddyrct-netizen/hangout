# Hangout Environment Variables
# Copy this file to .env and change the values for production

PROJECT_NAME="Hangout Production"
SECRET_KEY="replace-this-with-a-very-strong-random-secret-key"

# Database Configuration (PostgreSQL example)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://hangout_user:hangout_password@db:5432/hangout_db"

# CORS origins (for when running backend and frontend separately)
# In Docker production, both are served on the same origin.
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:8000"]
